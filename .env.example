PORT=3000
# Optional: comma-separated API keys. If unset, /v1/* is open (dev only).
# API_KEYS=sk_live_abc,sk_live_xyz

# Optional: for `npm run test:live` (hits real deployment, not .env on server)
# PAYLOADFIX_LIVE_URL=https://dev-payload-api.onrender.com
# PAYLOADFIX_API_KEY=...   # same as one of API_KEYS when the host requires X-API-Key

# Optional: directory for schema registry, drift logs, metering JSON (default ./data).
# On Render, point to a persistent disk mount so registry survives restarts.
# PAYLOADFIX_DATA_DIR=/var/data/payloadfix
