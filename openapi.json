{
  "openapi": "3.0.3",
  "info": {
    "title": "PayloadFix",
    "version": "0.5.0",
    "description": "Extract and repair JSON from messy LLM text. Validate against flat or nested schemas,\noptional registry (versioned schemas), drift logging, and metering.\nNo external LLM calls; all processing runs on this server.\nIf API_KEYS is set on the server, send header X-API-Key on /v1/* routes.\n",
    "termsOfService": "https://github.com/iami180/dev-payload-api/blob/main/README.md",
    "contact": {
      "name": "PayloadFix API",
      "url": "https://github.com/iami180/dev-payload-api"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "x-category": "Tools",
    "x-long-description": "PayloadFix cleans model output into structured JSON and validates it against your schema.\nUse POST /v1/llm/stabilize for parse/repair. Use POST /v1/llm/validate-schema for production\ncontracts (strict mode, coercion, contractEnforcement, driftReport). Registry endpoints store versioned schemas.\n",
    "x-website": "https://github.com/iami180/dev-payload-api",
    "x-public": true,
    "x-documentation": {
      "readme": "https://github.com/iami180/dev-payload-api/blob/main/RAPIDAPI_README.md"
    }
  },
  "servers": [
    {
      "url": "https://YOUR_HOST",
      "description": "Replace YOUR_HOST with your HTTPS base URL (no trailing slash)."
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Service metadata and liveness."
    },
    {
      "name": "LLM Output",
      "description": "Stabilize (parse/repair) and validate-schema."
    },
    {
      "name": "Registry",
      "description": "Stored schemas, versions, metering."
    },
    {
      "name": "Utilities",
      "description": "Text stats and SHA-256."
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Service metadata",
        "description": "Public. Returns service name, version, and docs path. No API key required.",
        "operationId": "getRootMeta",
        "security": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootMetaResponse"
                },
                "example": {
                  "service": "PayloadFix",
                  "tagline": "LLM output reliability: extract, repair, schema validation, coercion, and confidence for production pipelines",
                  "version": "0.5.0",
                  "docs": "/v1/health"
                }
              }
            }
          }
        }
      }
    },
    "/v1/health": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Liveness and endpoint list",
        "description": "Returns ok flag and a list of available endpoints.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                },
                "example": {
                  "ok": true,
                  "focus": "Structured LLM output — parse, validate, coerce, strict/lenient modes",
                  "endpoints": [
                    "POST /v1/llm/stabilize",
                    "POST /v1/llm/validate-schema",
                    "POST /v1/registry/schemas",
                    "GET /v1/registry/schemas",
                    "GET /v1/registry/schemas/:id",
                    "POST /v1/registry/schemas/:id/versions",
                    "GET /v1/registry/metering",
                    "POST /v1/text/stats",
                    "POST /v1/hash/sha256"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid X-API-Key when API_KEYS is configured on the server.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/llm/stabilize": {
      "post": {
        "tags": [
          "LLM Output"
        ],
        "summary": "Parse or repair JSON from LLM-style text",
        "description": "Strips markdown fences, runs extraction/repair. Does not guarantee a single business object root.\nOn failure returns 422 with code INVALID_JSON and repair diagnostics in error.details.\n",
        "operationId": "llmStabilize",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StabilizeRequest"
              },
              "example": {
                "raw": "Here is the result:\\n```json\\n{\"a\":1,}\\n```",
                "sortKeys": true,
                "pretty": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Parsed JSON (direct or after repair).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StabilizeSuccessResponse"
                },
                "example": {
                  "success": true,
                  "ok": true,
                  "method": "repaired",
                  "llmHints": [
                    "markdown_fence_removed"
                  ],
                  "warnings": [],
                  "data": {
                    "a": 1
                  },
                  "stringified": "{\n  \"a\": 1\n}"
                }
              }
            }
          },
          "400": {
            "description": "Invalid JSON body or request validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Could not extract valid JSON (INVALID_JSON).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StabilizeErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "INVALID_JSON",
                    "message": "Unexpected character",
                    "details": {
                      "parseCode": "invalid_json",
                      "failedStage": "syntax_repair",
                      "repairTrace": [
                        "ingest_raw",
                        "all_repair_paths_exhausted"
                      ],
                      "llmHints": []
                    }
                  },
                  "llmHints": [],
                  "warnings": []
                }
              }
            }
          }
        }
      }
    },
    "/v1/llm/validate-schema": {
      "post": {
        "tags": [
          "LLM Output"
        ],
        "summary": "Validate parsed object against a schema",
        "description": "Same preprocessing as stabilize, then root must be a plain JSON object.\nProvide either schema (inline) or schemaRef (registry). strict mode returns 422 on validation failure.\ncontractEnforcement forces strict plus reject on unknown keys.\n",
        "operationId": "llmValidateSchema",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ValidateSchemaRequest"
              },
              "example": {
                "raw": "{\"name\":\"A\",\"price\":\"10\"}",
                "schema": {
                  "name": "string",
                  "price": "number"
                },
                "coerceTypes": true,
                "mode": "strict"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "success true and payload satisfies schema (or lenient mode with diagnostics).",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateSchemaSuccessResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad body, Zod validation, or invalid nested schema definition.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "SCHEMA_REF_NOT_FOUND when schemaRef points to missing id or version.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "strict mode — PARSE_FAILED, ROOT_NOT_OBJECT, or SCHEMA_VALIDATION_FAILED.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateSchemaErrorResponse"
                },
                "example": {
                  "success": false,
                  "error": {
                    "code": "SCHEMA_VALIDATION_FAILED",
                    "message": "One or more fields failed schema validation."
                  },
                  "fieldErrors": [
                    {
                      "field": "price",
                      "code": "type_mismatch",
                      "message": "Field \"price\" expected type \"number\" but got string"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/registry/schemas": {
      "post": {
        "tags": [
          "Registry"
        ],
        "summary": "Register a new schema (version 1)",
        "description": "Creates a new schemaId. shapeDiffFromPrevious is always null in this response.",
        "operationId": "registryCreateSchema",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistryCreateRequest"
              },
              "example": {
                "name": "MyContract",
                "schema": {
                  "event": "string",
                  "quantity": "number"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "New schema id and version 1.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistryCreateResponse"
                },
                "example": {
                  "success": true,
                  "ok": true,
                  "schemaId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                  "version": 1,
                  "shapeDiffFromPrevious": null
                }
              }
            }
          },
          "400": {
            "description": "Invalid body or schema limits exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Registry"
        ],
        "summary": "List registered schemas",
        "description": "Returns id, name, latestVersion, versionCount for each schema.",
        "operationId": "registryListSchemas",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistryListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized when API_KEYS is set.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/registry/schemas/{id}": {
      "get": {
        "tags": [
          "Registry"
        ],
        "summary": "Get full schema document",
        "description": "All versions with schema JSON and optional changelog and shapeDiffFromPrevious per version.",
        "operationId": "registryGetSchema",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Schema id returned from POST /v1/registry/schemas.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistryDocumentResponse"
                }
              }
            }
          },
          "404": {
            "description": "NOT_FOUND — unknown schema id.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/registry/schemas/{id}/versions": {
      "post": {
        "tags": [
          "Registry"
        ],
        "summary": "Add a new schema version",
        "description": "Returns new version number and shapeDiffFromPrevious compared to the previous version.",
        "operationId": "registryAddVersion",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Schema id.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistryVersionRequest"
              },
              "example": {
                "schema": {
                  "event": "string",
                  "quantity": "number",
                  "fulfilled": "boolean"
                },
                "changelog": "Add fulfilled field"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegistryVersionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid body or schema limits.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "NOT_FOUND — unknown schema id.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/registry/metering": {
      "get": {
        "tags": [
          "Registry"
        ],
        "summary": "Aggregate metering counters",
        "description": "Counts stabilize/validateSchema success and totals, plus registry events.",
        "operationId": "registryGetMetering",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MeteringWrapperResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized when API_KEYS is set.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/text/stats": {
      "post": {
        "tags": [
          "Utilities"
        ],
        "summary": "Character, line, and word statistics",
        "description": "roughTokensLlMHint is approximately chars divided by 4, not a real tokenizer.",
        "operationId": "textStats",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TextStatsRequest"
              },
              "example": {
                "text": "hello world\nline two"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TextStatsResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid body or validation failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/hash/sha256": {
      "post": {
        "tags": [
          "Utilities"
        ],
        "summary": "SHA-256 hash of UTF-8 text or raw hex bytes",
        "description": "encoding hex requires even-length hexadecimal string.",
        "operationId": "hashSha256",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HashSha256Request"
              },
              "example": {
                "text": "payload",
                "encoding": "utf8"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Sha256Response"
                }
              }
            }
          },
          "400": {
            "description": "Invalid body, validation failed, or INVALID_HEX_INPUT for hex mode.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StandardErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key",
        "description": "Required when the server environment variable API_KEYS is set (comma-separated keys)."
      }
    },
    "schemas": {
      "StandardErrorResponse": {
        "type": "object",
        "required": [
          "success",
          "error"
        ],
        "description": "Standard API error envelope.",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Always false for this shape.",
            "enum": [
              false
            ]
          },
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "description": "Error code and human-readable message.",
            "properties": {
              "code": {
                "type": "string",
                "description": "Machine-readable error code."
              },
              "message": {
                "type": "string",
                "description": "Human-readable summary."
              },
              "details": {
                "type": "object",
                "description": "Optional structured details (e.g. Zod issues).",
                "additionalProperties": true
              }
            }
          }
        }
      },
      "RootMetaResponse": {
        "type": "object",
        "description": "Root GET response.",
        "properties": {
          "service": {
            "type": "string",
            "description": "Service name."
          },
          "tagline": {
            "type": "string",
            "description": "Short product description."
          },
          "version": {
            "type": "string",
            "description": "API version string."
          },
          "docs": {
            "type": "string",
            "description": "Path to health/docs endpoint."
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "ok",
          "endpoints"
        ],
        "description": "Health check payload.",
        "properties": {
          "ok": {
            "type": "boolean",
            "description": "Always true when healthy."
          },
          "focus": {
            "type": "string",
            "description": "Short capability summary."
          },
          "endpoints": {
            "type": "array",
            "description": "List of available endpoint strings.",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "StabilizeRequest": {
        "type": "object",
        "required": [
          "raw"
        ],
        "description": "Input text from an LLM or chat transcript.",
        "properties": {
          "raw": {
            "type": "string",
            "description": "Raw text that may contain JSON, fences, or prose.",
            "minLength": 1
          },
          "sortKeys": {
            "type": "boolean",
            "description": "Sort object keys in the parsed result (default true).",
            "default": true
          },
          "pretty": {
            "type": "boolean",
            "description": "Pretty-print stringified output (default true).",
            "default": true
          },
          "preferJsonBlock": {
            "type": "string",
            "description": "When multiple top-level object blocks exist, pick first, last, or largest.",
            "enum": [
              "first",
              "last",
              "largest"
            ]
          }
        }
      },
      "StabilizeSuccessResponse": {
        "type": "object",
        "required": [
          "success",
          "ok",
          "method",
          "llmHints",
          "warnings",
          "data",
          "stringified"
        ],
        "description": "Successful stabilize response.",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "ok": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "method": {
            "type": "string",
            "description": "direct or repaired.",
            "enum": [
              "direct",
              "repaired"
            ]
          },
          "repairedFrom": {
            "type": "string",
            "description": "Repair tool name when method is repaired."
          },
          "llmHints": {
            "type": "array",
            "description": "Pipeline hints applied to the input.",
            "items": {
              "type": "string"
            }
          },
          "warnings": {
            "type": "array",
            "description": "Non-fatal warnings (e.g. ambiguous fragments).",
            "items": {
              "type": "string"
            }
          },
          "data": {
            "type": "object",
            "description": "Parsed JSON value (object, array, or primitive).",
            "additionalProperties": true
          },
          "stringified": {
            "type": "string",
            "description": "JSON string of data, formatted per pretty flag."
          }
        }
      },
      "StabilizeErrorResponse": {
        "type": "object",
        "required": [
          "success",
          "error",
          "llmHints",
          "warnings"
        ],
        "description": "Stabilize failure (HTTP 422). error.code is INVALID_JSON.",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "error": {
            "type": "object",
            "required": [
              "code",
              "message"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "INVALID_JSON",
                "enum": [
                  "INVALID_JSON"
                ]
              },
              "message": {
                "type": "string"
              },
              "details": {
                "type": "object",
                "description": "May include parseCode, hint, failedStage, repairTrace, llmHints.",
                "additionalProperties": true
              }
            }
          },
          "llmHints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SchemaRef": {
        "type": "object",
        "required": [
          "schemaId"
        ],
        "description": "Reference to a schema stored in the registry.",
        "properties": {
          "schemaId": {
            "type": "string",
            "description": "Registry schema id.",
            "minLength": 8,
            "maxLength": 128
          },
          "version": {
            "type": "integer",
            "description": "Optional pinned version; latest if omitted.",
            "minimum": 1
          }
        }
      },
      "ValidateSchemaRequest": {
        "type": "object",
        "required": [
          "raw"
        ],
        "description": "Exactly one of schema or schemaRef must be present (validated by the server).\nraw is model output text (max 512 KiB).\n",
        "properties": {
          "raw": {
            "type": "string",
            "description": "LLM output string to parse then validate.",
            "minLength": 1
          },
          "schema": {
            "type": "object",
            "description": "Inline flat or nested schema object.",
            "additionalProperties": true
          },
          "schemaRef": {
            "$ref": "#/components/schemas/SchemaRef"
          },
          "required": {
            "type": "array",
            "description": "Field names that must be present in the parsed object.",
            "maxItems": 100,
            "items": {
              "type": "string"
            }
          },
          "coerceTypes": {
            "type": "boolean",
            "description": "Coerce string numbers/booleans where possible.",
            "default": false
          },
          "mode": {
            "type": "string",
            "description": "strict returns 422 on validation failure; lenient may return 200 with errors in body.",
            "enum": [
              "strict",
              "lenient"
            ],
            "default": "strict"
          },
          "unknownFieldPolicy": {
            "type": "string",
            "description": "How to handle keys not in the schema.",
            "enum": [
              "allow",
              "reject",
              "strip",
              "report"
            ],
            "default": "allow"
          },
          "contractEnforcement": {
            "type": "boolean",
            "description": "Forces strict mode and reject policy on unknown keys.",
            "default": false
          },
          "driftLog": {
            "type": "boolean",
            "description": "When true and schemaRef is used, append a line to server drift log.",
            "default": true
          },
          "richFailureExplanations": {
            "type": "boolean",
            "description": "Include richFailures and failureExplanation on errors when true.",
            "default": true
          }
